{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2019",
    "module": "commonjs",
    "resolveJsonModule": true,
    "declaration": true,
    "removeComments": false,
    "importHelpers": true,
    "downlevelIteration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2019"],
  },
  "include": ["./src"],
  "exclude": ["**/*.test.ts", "./dist/**/*"]
}
